APP_URL="http://localhost:3000"
NODE_ENV="development"

# Supabase PostgreSQL / Prisma
# DATABASE_URL is used by the app runtime. Prefer Supabase pooler transaction mode for deployed/serverless runtime.
DATABASE_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL is used by Prisma migration/seed commands. Prefer Supabase pooler session mode or direct connection.
DIRECT_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="replace-with-a-secure-random-secret"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Supabase project metadata
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Brevo / SMTP-compatible email
BREVO_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="Summit Gear <no-reply@summitgear.local>"

# Midtrans
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Shipping
RAJAONGKIR_API_KEY=""
BINDERBYTE_API_KEY=""

# Analytics / monitoring
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""
