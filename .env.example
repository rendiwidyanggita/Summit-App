APP_URL="http://localhost:3000"
NODE_ENV="development"
# Enables demo-only behavior such as simulated Midtrans settlement.
# Never enable this flag for a real production store.
DEMO_MODE="true"

# Supabase PostgreSQL / Prisma
# DATABASE_URL is used by the app runtime. Prefer Supabase pooler transaction mode for deployed/serverless runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL is used by Prisma migration/seed commands. Prefer Supabase pooler session mode or direct connection.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="replace-with-a-secure-random-secret"
AUTH_TRUST_HOST="true"
# Required for active Google OAuth.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Optional and currently postponed for the demo.
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Supabase project metadata
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Brevo / SMTP-compatible email
# Required for Sprint 2 email verification and reset password delivery.
BREVO_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="Summit Gear <no-reply@summitgear.local>"

# Midtrans
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# Demo mode: set DEMO_MODE=true and this flag to true to use simulated payments without Midtrans keys.
MIDTRANS_MOCK_ENABLED="true"

# Shipping
RAJAONGKIR_API_KEY=""
BINDERBYTE_API_KEY=""

# Analytics / monitoring
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""
