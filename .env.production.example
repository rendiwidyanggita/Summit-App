# Production Environment Variables for Vercel Deployment
# Copy values dari file ini ke Vercel Dashboard → Settings → Environment Variables

# === REQUIRED VARIABLES ===

# Application URL (set to your Vercel domain)
APP_URL="https://your-app.vercel.app"
NODE_ENV="production"

# IMPORTANT: Set to "false" for production
# DEMO_MODE enables simulated payments without real transactions
DEMO_MODE="false"

# Database (Supabase PostgreSQL)
# DATABASE_URL uses connection pooler (port 6543) for serverless
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL uses direct connection (port 5432) for migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-secure-random-secret-key-here"
AUTH_TRUST_HOST="true"

# === OPTIONAL BUT RECOMMENDED ===

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Brevo for transactional emails
BREVO_API_KEY=""
EMAIL_FROM="Summit Gear <noreply@yourdomain.com>"

# Midtrans Payment Gateway
# Get from: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# Set to "false" in production to use real Midtrans
MIDTRANS_MOCK_ENABLED="false"

# Shipping calculation (optional)
RAJAONGKIR_API_KEY=""
BINDERBYTE_API_KEY=""

# === VERCEL-SPECIFIC NOTES ===
# 1. Add all variables di Vercel Dashboard → Settings → Environment Variables
# 2. Pilih environment: Production, Preview, Development
# 3. Untuk secrets (API keys, passwords), gunakan "Sensitive" flag
# 4. APP_URL akan auto-set oleh Vercel jika tidak diisi manual
# 5. NODE_ENV auto-set oleh Vercel, tapi bisa di-override jika perlu

# === SECURITY CHECKLIST ===
# ✓ AUTH_SECRET must be unique and secure (min 32 characters)
# ✓ Never commit this file with real values to Git
# ✓ DEMO_MODE must be "false" for production
# ✓ Use Supabase connection pooler (port 6543) for DATABASE_URL
# ✓ All API keys should be marked as "Sensitive" in Vercel
# ✓ Verify MIDTRANS_IS_PRODUCTION matches your Midtrans environment
